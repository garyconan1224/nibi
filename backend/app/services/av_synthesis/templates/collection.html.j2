<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ ctx.title }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif;
    color: #111;
    background: #fff;
    line-height: 1.7;
    padding: 40px 48px;
    max-width: 800px;
    margin: 0 auto;
  }
  h1 { font-size: 28px; margin-bottom: 8px; color: #111; }
  h2 {
    font-size: 20px;
    margin-top: 32px;
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 2px solid #FF4D7E;
    color: #111;
  }
  h3 { font-size: 16px; margin-top: 20px; margin-bottom: 8px; color: #3a3a3a; }
  p { margin-bottom: 10px; }
  blockquote {
    border-left: 3px solid #B84CFF;
    padding: 8px 16px;
    margin: 12px 0;
    background: #f6f5f0;
    color: #3a3a3a;
    font-size: 14px;
    border-radius: 0 4px 4px 0;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 14px;
  }
  th {
    background: #f6f5f0;
    text-align: left;
    padding: 8px 12px;
    border-bottom: 2px solid rgba(0,0,0,0.08);
    font-weight: 600;
  }
  td {
    padding: 8px 12px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    vertical-align: top;
  }
  td img { max-width: 120px; max-height: 80px; border-radius: 4px; }
  pre, code {
    background: #f6f5f0;
    border-radius: 4px;
    font-size: 13px;
  }
  pre { padding: 12px 16px; overflow-x: auto; margin: 12px 0; }
  code { padding: 2px 5px; }
  ul, ol { margin: 8px 0 12px 24px; }
  img { max-width: 100%; border-radius: 6px; margin: 8px 0; }
  .collection-header { margin-bottom: 32px; }
  .collection-meta { color: #6b6b6b; font-size: 14px; margin-bottom: 24px; }
  .note-section {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    page-break-inside: avoid;
  }
  .note-section:last-child { border-bottom: none; }
  .note-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 6px;
    color: #111;
  }
  .note-type {
    display: inline-block;
    font-size: 11px;
    font-family: monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 12px;
  }
  .footer {
    margin-top: 40px;
    padding-top: 16px;
    border-top: 1px solid rgba(0,0,0,0.08);
    color: #a0a0a0;
    font-size: 12px;
    text-align: center;
  }
  @media print {
    body { padding: 24px; }
    .note-section { page-break-inside: avoid; }
  }
</style>
</head>
<body>

<div class="collection-header">
  <h1>{{ ctx.title }}</h1>
  <div class="collection-meta">{{ ctx.material_count }} 个素材 · 由 Nibi 导出 · {{ ctx.date }}</div>
</div>

{% for note in ctx.notes %}
<div class="note-section">
  <div class="note-title">{{ note.title }}</div>
  <div class="note-type">{{ note.item_type }}</div>
  {{ note.html }}
</div>
{% endfor %}

<div class="footer">由 Nibi 生成 · {{ ctx.date }}</div>

</body>
</html>
