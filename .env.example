# 复制为 .env 后填写（.env 已被 gitignore，勿提交）
#
# ── OpenAI 兼容端（硅基流动 / DeepSeek 官方 / OpenRouter / Together 等）────
# 任选其一作为 Key；优先级见 shared/api_key_resolver.py
SILICONFLOW_API_KEY=your_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=
# OPENAI_API_KEY=

# 可选：覆盖默认硅基地址；留空则使用 https://api.siliconflow.cn/v1
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_COMPAT_BASE_URL=

# ── Anthropic（仅创作工作台「文本后端」选 Anthropic 时需要）────────────────
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# ── 前后端端口联动（单一来源，前后端共享）──────────────────────────────────
# Vite 开发服务器端口；后端用它动态生成 CORS 白名单，未设置时回退 5177
# VITE_PORT=5177
# 可选：显式 CORS origin 列表（逗号分隔完整 URL），非空时优先于 VITE_PORT 推导
# CORS_ALLOW_ORIGINS=http://localhost:5177,http://127.0.0.1:5177

# ── Backend / Transcript / ASR（任务中心与转写服务）──────────────────────────
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
# Streamlit 请求任务中心时使用（默认 http://127.0.0.1:8000）
# VIDMIRROR_BACKEND_URL=http://127.0.0.1:8000
# BACKEND_URL=http://127.0.0.1:8000
# GROQ_API_KEY=
# GROQ_ASR_MODEL=whisper-large-v3
# FAST_WHISPER_MODEL=base
# FAST_WHISPER_DEVICE=cpu
